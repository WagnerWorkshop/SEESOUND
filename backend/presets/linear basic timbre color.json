{
  "name": "linear basic timbre color",
  "params": {
    "inputGain": 0.48,
    "amplitudeThreshold": 0,
    "defaultParticleSize": 0.3,
    "canvasWidth": 3000,
    "canvasHeight": 1000,
    "canvasScale": 40,
    "maxParticles": 1999872,
    "particleRenderPercent": 50,
    "blendMode": "screen",
    "cameraProjection": "axonometric",
    "cameraAxoPreset": "orthoXY",
    "persistMode": 1,
    "tonicHz": 261.63,
    "ruleBlocks": [
      {
        "id": "x-set-time",
        "group": "SPACING",
        "subgroup": "x coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "x",
            "input": "time"
          }
        ],
        "order": 0
      },
      {
        "id": "x-divide-by-audio-length",
        "group": "SPACING",
        "subgroup": "x coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "divide",
            "output": "x",
            "expression": "(audioLengthSec) * 1.12"
          }
        ],
        "order": 1
      },
      {
        "id": "y-set-norm-frequency",
        "group": "SPACING",
        "subgroup": "y coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "y",
            "input": "normFreq"
          }
        ],
        "order": 2
      },
      {
        "id": "y-center-around-zero",
        "group": "SPACING",
        "subgroup": "y coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "subtract",
            "output": "y",
            "value": 0.5
          }
        ],
        "order": 3
      },
      {
        "id": "y-scale-to-canvas-height",
        "group": "SPACING",
        "subgroup": "y coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "multiply",
            "output": "y",
            "expression": "(canvasHeightPx) * 1"
          }
        ],
        "order": 4
      },
      {
        "id": "x-center-around-zero",
        "group": "SPACING",
        "subgroup": "x coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "subtract",
            "output": "x",
            "value": 0.5
          }
        ],
        "order": 5
      },
      {
        "id": "x-scale-to-canvas-width",
        "group": "SPACING",
        "subgroup": "x coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "multiply",
            "output": "x",
            "expression": "(canvasWidthUnits) * 1"
          }
        ],
        "order": 6
      },
      {
        "id": "amplitude brightness",
        "group": "Appearance",
        "subgroup": "brightness",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "brightness",
            "input": "binEnergy"
          }
        ],
        "order": 7
      },
      {
        "id": "ear correction",
        "group": "Appearance",
        "subgroup": "brightness",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "multiply",
            "output": "opacity",
            "expression": "clamp(0.2 + abs(binFlux) * 4 + binEnergy * 1.2, 0, 4)"
          }
        ],
        "order": 8
      },
      {
        "id": "ear correction-2",
        "group": "Appearance",
        "subgroup": "brightness",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "multiply",
            "output": "opacity",
            "expression": "clamp(0.25 + binPhaseDeviation * 1.8, 0.25, 2.5)"
          }
        ],
        "order": 9
      },
      {
        "id": "thinning",
        "group": "Appearance",
        "subgroup": "brightness",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "particleCount",
            "input": "binEnergy"
          }
        ],
        "order": 10
      },
      {
        "id": "timbre hue",
        "group": "Appearance",
        "subgroup": "color",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "hue",
            "expression": "clamp(normFreq * 0.78 + abs(binFlux) * 0.35 + binPhaseDeviation * 0.25 + (binEnvelope / 3) * 0.12, 0, 1)"
          }
        ],
        "order": 11
      },
      {
        "id": "timbre saturation",
        "group": "Appearance",
        "subgroup": "color",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "saturation",
            "expression": "clamp(0.25 + abs(binFlux) * 0.55 + binPhaseDeviation * 0.35 + (1 - spectralFlatness) * 0.2, 0, 1)"
          }
        ],
        "order": 12
      },
      {
        "id": "background hue",
        "group": "Default",
        "subgroup": "background color",
        "enabled": false,
        "target": "background",
        "scope": "allLivingFrame",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "hue",
            "value": 0.08
          }
        ],
        "order": 13
      },
      {
        "id": "background saturation",
        "group": "Default",
        "subgroup": "background color",
        "enabled": false,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "saturation",
            "value": 0.35
          }
        ],
        "order": 14
      },
      {
        "id": "soft",
        "group": "Appearance",
        "subgroup": "size",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "multiply",
            "output": "size",
            "expression": "clamp(0.3 + binEnergy * 4 + abs(binFlux) * 2 + binPhaseDeviation * 1.5, 0.3, 7)"
          }
        ],
        "order": 15
      },
      {
        "id": "shape",
        "group": "Default",
        "subgroup": "",
        "enabled": true,
        "target": "allParticles",
        "scope": "allLivingFrame",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "shapeType",
            "value": "circle"
          }
        ],
        "order": 16
      }
    ],
    "ruleEngineEnabled": true,
    "ruleSchemaVersion": 1,
    "_disabled": [],
    "freqNormMin": 64.0,
    "freqNormMax": 16000.0,
    "binFluxNormMin": 0.0,
    "binPhaseDeviationNormMin": 0.0,
    "spectralFlatnessNormMax": 1.0,
    "binMagnitudeNormMin": -70,
    "binAttackTimeNormMax": 500,
    "spectralFlatnessNormMin": 0.0,
    "globalRmsNormMin": -60,
    "globalSpectralFluxNormMax": 100.0,
    "spectralCentroidNormMin": 150,
    "binPhaseDeviationNormMax": 3.14,
    "globalRmsNormMax": 0,
    "globalSpectralFluxNormMin": 0.0,
    "binMagnitudeNormMax": 0,
    "spectralCentroidNormMax": 8000,
    "binFluxNormMax": 0.5,
    "binAttackTimeNormMin": 5
  }
}
