      {
        "id": "x-set-time",
        "group": "SPACING",
        "subgroup": "x coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "x",
            "input": "time"
          }
        ],
        "order": 0
      },
      {
