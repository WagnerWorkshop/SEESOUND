{
  "name": "pan frequency perceptual timbre",
  "params": {
    "inputGain": 1,
    "amplitudeThreshold": -48,
    "freqNormMin": 32,
    "freqNormMax": 18000,
    "fftSize": 16384,
    "binMagnitudeNormMin": -70,
    "binMagnitudeNormMax": 0,
    "binFluxNormMin": 0,
    "binFluxNormMax": 0.5,
    "binPhaseDeviationNormMin": 0,
    "binPhaseDeviationNormMax": 3.14,
    "binAttackTimeNormMin": 5,
    "binAttackTimeNormMax": 500,
    "globalRmsNormMin": -60,
    "globalRmsNormMax": 0,
    "spectralCentroidNormMin": 150,
    "spectralCentroidNormMax": 8000,
    "globalSpectralFluxNormMin": 0,
    "globalSpectralFluxNormMax": 100,
    "spectralFlatnessNormMin": 0,
    "spectralFlatnessNormMax": 1,
    "defaultParticleSize": 4,
    "canvasWidth": 2400,
    "canvasHeight": 1200,
    "canvasScale": 60,
    "defaultBackgroundHue": 0,
    "defaultBackgroundSaturation": 0,
    "defaultBackgroundLightness": 0,
    "maxParticles": 1200000,
    "particleRenderPercent": 85,
    "particlesPerOctave": 500,
    "blendMode": "screen",
    "cameraProjection": "axonometric",
    "cameraAxoPreset": "orthoXY",
    "persistMode": 1,
    "tonicHz": 261.63,
    "ruleBlocks": [
      {
        "id": "x-from-pan",
        "group": "SPATIAL",
        "subgroup": "position",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "x",
            "expression": "(pan) * (canvasWidthPx) * 5"
          }
        ],
        "order": 0
      },
      {
        "id": "y-from-frequency",
        "group": "SPATIAL",
        "subgroup": "position",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "y",
            "expression": "((normFreq) - 0.5) * (canvasHeightPx) *5"
          }
        ],
        "order": 1
      },
      {
        "id": "z-perceptual-distance",
        "group": "SPATIAL",
        "subgroup": "depth",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "z",
            "expression": "-(1 - binMagnitude) * max(canvasWidthPx, canvasHeightPx) * 2"
          }
        ],
        "order": 2
      },
      {
        "id": "brightness-from-bin-energy",
        "group": "COLOR",
        "subgroup": "value",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "brightness",
            "input": "binMagnitude"
          }
        ],
        "order": 3
      },
      {
        "id": "hue-sharp-yellow-soft-blue",
        "group": "COLOR",
        "subgroup": "hue",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "hue",
            "expression": "0.62 - spectralFlatness * 0.46"
          }
        ],
        "order": 4
      },
      {
        "id": "saturation-from-sharpness",
        "group": "COLOR",
        "subgroup": "saturation",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "saturation",
            "expression": "0.2 + spectralFlatness * 0.8"
          }
        ],
        "order": 5
      },
      {
        "id": "opacity-from-energy",
        "group": "COLOR",
        "subgroup": "alpha",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "opacity",
            "expression": "0.12 + binMagnitude * 0.88"
          }
        ],
        "order": 6
      }
    ],
    "ruleEngineEnabled": true,
    "ruleSchemaVersion": 1,
    "_disabled": [],
    "cameraFov": 104,
    "enableAggressiveThinning": true,
    "dominantPeakCulling": true,
    "peakEnergyThreshold": 0.18,
    "uiDirectives": {
      "responsiveInterface": true,
      "resizableAndCollapsibleTabs": true,
      "tooltipsForAllControls": true,
      "tooltipContent": "feature_and_current_value"
    }
  }
}