{
    "name": "reactive core energy chaos",
    "params": {
        "inputGain": 1,
        "amplitudeThreshold": -56,
        "defaultParticleSize": 2,
        "canvasWidth": 2400,
        "canvasHeight": 1400,
        "canvasScale": 52,
        "maxParticles": 2000000,
        "particleRenderPercent": 28,
        "blendMode": "screen",
        "cameraProjection": "perspective",
        "cameraAxoPreset": "orthoXY",
        "persistMode": 1,
        "tonicHz": 261.63,
        "ruleBlocks": [
            {
                "id": "gatekeeper-low-bin-magnitude",
                "group": "GATE",
                "subgroup": "gatekeeper",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "<",
                    "input": "binMagnitude",
                    "value": 0.1
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "opacity",
                        "value": 0
                    },
                    {
                        "operator": "set",
                        "output": "particleCount",
                        "value": 0
                    }
                ],
                "order": 0
            },
            {
                "id": "x-spread-from-pan-times-spectral-spread",
                "group": "SPATIAL",
                "subgroup": "X",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "always"
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "x",
                        "expression": "pan * (canvasWidthPx) * 0.45 * clamp(0.1 + spectralSpread * 1.25, 0.1, 1.4)"
                    }
                ],
                "order": 1
            },
            {
                "id": "y-spread-from-normfreq-times-spectral-spread",
                "group": "SPATIAL",
                "subgroup": "Y",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "always"
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "y",
                        "expression": "(normFreq - 0.5) * (canvasHeightPx) * clamp(0.1 + spectralSpread * 1.25, 0.1, 1.4)"
                    }
                ],
                "order": 2
            },
            {
                "id": "z-from-bin-phase-cycle",
                "group": "SPATIAL",
                "subgroup": "Z",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "always"
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "z",
                        "expression": "(binPhase - 0.5) * max(canvasWidthPx, canvasHeightPx) * 0.72"
                    }
                ],
                "order": 3
            },
            {
                "id": "hue-from-global-spectral-centroid",
                "group": "COLOR",
                "subgroup": "HUE",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "always"
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "hue",
                        "input": "spectralCentroid"
                    }
                ],
                "order": 4
            },
            {
                "id": "size-from-bin-magnitude-plus-bass",
                "group": "APPEARANCE",
                "subgroup": "SIZE",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "always"
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "size",
                        "expression": "0.2 + clamp(binMagnitude + bass * 0.6, 0, 1) * 6"
                    }
                ],
                "order": 5
            },
            {
                "id": "opacity-from-bin-magnitude",
                "group": "APPEARANCE",
                "subgroup": "OPACITY",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "always"
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "opacity",
                        "expression": "clamp(binMagnitude * 1.35, 0, 1)"
                    }
                ],
                "order": 6
            },
            {
                "id": "shape-tonal-circle",
                "group": "APPEARANCE",
                "subgroup": "SHAPE",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": "<=",
                    "input": "binPhaseDeviation",
                    "value": 0.5
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "shapeType",
                        "value": "circle"
                    }
                ],
                "order": 7
            },
            {
                "id": "shape-noisy-square",
                "group": "APPEARANCE",
                "subgroup": "SHAPE",
                "enabled": true,
                "target": "spawnedParticles",
                "scope": "spawnedOnly",
                "condition": {
                    "operator": ">",
                    "input": "binPhaseDeviation",
                    "value": 0.5
                },
                "actions": [
                    {
                        "operator": "set",
                        "output": "shapeType",
                        "value": "square"
                    }
                ],
                "order": 8
            }
        ],
        "ruleEngineEnabled": true,
        "ruleSchemaVersion": 1,
        "_disabled": [],
        "freqNormMin": 64,
        "freqNormMax": 20000,
        "binFluxNormMin": 0,
        "binFluxNormMax": 0.5,
        "binPhaseDeviationNormMin": 0,
        "binPhaseDeviationNormMax": 3.14,
        "binMagnitudeNormMin": -70,
        "binMagnitudeNormMax": 0,
        "globalRmsNormMin": -60,
        "globalRmsNormMax": 0,
        "globalSpectralFluxNormMin": 0,
        "globalSpectralFluxNormMax": 100,
        "spectralCentroidNormMin": 150,
        "spectralCentroidNormMax": 8000,
        "spectralFlatnessNormMin": 0,
        "spectralFlatnessNormMax": 1,
        "binAttackTimeNormMin": 5,
        "binAttackTimeNormMax": 500
    }
}