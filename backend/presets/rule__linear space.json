        "group": "SPACING",
        "subgroup": "y coordinate",
        "enabled": true,
        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "subtract",
            "output": "y",
