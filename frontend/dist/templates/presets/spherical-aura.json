{    "schemaVersion": 3,    "name": "spherical-aura",    "params": {        "inputGain": 0.8,        "freqNormMin": 40,        "freqNormMax": 10000,        "frequencyFftSize": 16384,        "cqtDetailsPer10Octaves": 1000,        "fluxWindowFrames": 12,        "binMagnitudeNormMin": -70,        "binMagnitudeNormMax": 0,        "globalRmsNormMin": -60,        "globalRmsNormMax": 0,        "spectralCentroidNormMin": 150,        "spectralCentroidNormMax": 8000,        "spectralFlatnessNormMin": 0,        "spectralFlatnessNormMax": 1,        "defaultParticleSize": 2,        "canvasWidth": 1500,        "canvasHeight": 1500,        "canvasScale": 45,        "defaultBackgroundHue": 300,        "defaultBackgroundSaturation": 20,        "defaultBackgroundLightness": 5,        "maxParticles": 1500000,        "particlesByFrame": 1000,        "blendMode": "screen",        "blendEnabled": 1,        "cameraProjection": "perspective",        "cameraPosZ": 800,        "persistMode": 0,        "postProcessEnabled": 1,        "bloomEnabled": 1,        "bloomStrength": 1.0,        "bloomRadius": 0.7,        "bloomThreshold": 0.2,        "fogEnabled": 0,        "ruleEngineEnabled": true,        "ruleSchemaVersion": 3,        "palettes": [],        "tuners": [],        "ruleUiState": {            "collapsedGroups": [],            "collapsedSubgroups": [],            "collapsedRules": [],            "selectedContextGroup": "allParticles"        },        "ruleEntities": [            {                "id": "layer-sphere",                "name": "Spherical Cloud",                "enabled": true,                "order": 0,                "layerShapeType": "cloud",                "spacingMode": "coordinates",                "cloudShape": "spherical",                "definitions": [],                "rules": [                    {                        "id": "rule-x-fundamental",                        "enabled": true,                        "target": "spawnedParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "x",                                "expression": "(time / audioLengthSec - 0.5) * 400"                            }                        ],                        "order": 0                    },                    {                        "id": "rule-y-fundamental",                        "enabled": true,                        "target": "spawnedParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "y",                                "expression": "(spectralCentroid - 0.5) * 400"                            }                        ],                        "order": 1                    },                    {                        "id": "rule-z-fundamental",                        "enabled": true,                        "target": "spawnedParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "z",                                "expression": "(binPhase - 0.5) * 400"                            }                        ],                        "order": 2                    },                    {                        "id": "rule-cloudsize",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "cloudSize",                                "expression": "0.3 + amplitude * 0.7"                            }                        ],                        "order": 3                    },                    {                        "id": "rule-aura-distance",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "auraDistance",                                "expression": "0.2 + binMagnitude * 0.8"                            }                        ],                        "order": 4                    },                    {                        "id": "rule-aura-longitude",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "auraAngle",                                "expression": "normFreq"                            }                        ],                        "order": 5                    },                    {                        "id": "rule-aura-latitude",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "auraLatitude",                                "expression": "spectralCentroid"                            }                        ],                        "order": 6                    },                    {                        "id": "rule-size",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "size",                                "expression": "0.5 + componentVolume * 3"                            }                        ],                        "order": 7                    },                    {                        "id": "rule-hue",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "hue",                                "expression": "fundamentalHz / 2000"                            }                        ],                        "order": 8                    },                    {                        "id": "rule-saturation",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "saturation",                                "expression": "0.5 + componentFlatness * 0.5"                            }                        ],                        "order": 9          