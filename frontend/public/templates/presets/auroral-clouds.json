{
    "schemaVersion": 3,
    "name": "auroral-clouds",
    "params": {
        "inputGain": 0.9,
        "freqNormMin": 60,
        "freqNormMax": 8000,
        "frequencyFftSize": 16384,
        "cqtDetailsPer10Octaves": 1000,
        "fluxWindowFrames": 10,
        "binMagnitudeNormMin": -70,
        "binMagnitudeNormMax": 0,
        "globalRmsNormMin": -60,
        "globalRmsNormMax": 0,
        "spectralCentroidNormMin": 150,
        "spectralCentroidNormMax": 8000,
        "spectralFlatnessNormMin": 0,
        "spectralFlatnessNormMax": 1,
        "defaultParticleSize": 3,
        "canvasWidth": 2000,
        "canvasHeight": 1200,
        "canvasScale": 45,
        "defaultBackgroundHue": 240,
        "defaultBackgroundSaturation": 30,
        "defaultBackgroundLightness": 3,
        "maxParticles": 2000000,
        "particlesByFrame": 2000,
        "blendMode": "screen",
        "blendEnabled": 1,
        "cameraProjection": "axonometric",
        "cameraAxoPreset": "orthoXY",
        "cameraPosZ": 500,
        "persistMode": 0,
        "postProcessEnabled": 1,
        "bloomEnabled": 1,
        "bloomStrength": 1.5,
        "bloomRadius": 0.5,
        "bloomThreshold": 0.15,
        "fogEnabled": 1,
        "fogDensity": 0.0005,
        "ruleEngineEnabled": true,
        "ruleSchemaVersion": 3,
        "palettes": [],
        "tuners": [],
        "ruleUiState": {
            "collapsedGroups": [],
            "collapsedSubgroups": [],
            "collapsedRules": [],
            "selectedContextGroup": "allParticles"
        },
        "ruleEntities": [
            {
                "id": "entity-auroral",
                "name": "Auroral Cloud",
                "enabled": true,
                "order": 0,
                "entityShapeType": "cloud",
                "spacingMode": "coordinates",
                "cloudShape": "cylindrical",
                "definitions": [],
                "rules": [
                    {
                        "id": "rule-x-fundamental",
                        "enabled": true,
                        "target": "spawnedParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "x",
                                "expression": "(time / audioLengthSec - 0.5) * canvasWidth * 0.8"
                            }
                        ],
                        "order": 0
                    },
                    {
                        "id": "rule-y-fundamental",
                        "enabled": true,
                        "target": "spawnedParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "y",
                                "expression": "0"
                            }
                        ],
                        "order": 1
                    },
                    {
                        "id": "rule-z-fundamental",
                        "enabled": true,
                        "target": "spawnedParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "z",
                                "expression": "(spectralCentroid - 0.5) * 200"
                            }
                        ],
                        "order": 2
                    },
                    {
                        "id": "rule-cloudsize-global",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "cloudSize",
                                "expression": "0.5 + amplitude * 0.5"
                            }
                        ],
                        "order": 3
                    },
                    {
                        "id": "rule-aura-distance",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "auraDistance",
                                "expression": "0.3 + binMagnitude * 0.7"
                            }
                        ],
                        "order": 4
                    },
                    {
                        "id": "rule-aura-angle",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "auraAngle",
                                "expression": "fundamentalNote / 12"
                            }
                        ],
                        "order": 5
                    },
                    {
                        "id": "rule-aura-elevation",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "auraElevation",
                                "expression": "spectralCentroid"
                            }
                        ],
                        "order": 6
                    },
                    {
                        "id": "rule-size-entity",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "size",
                                "expression": "0.5 + entityVolume * 3"
                            }
                        ],
                        "order": 7
                    },
                    {
                        "id": "rule-hue-entity",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "hue",
                                "expression": "fundamentalHz / 2000"
                            }
                        ],
                        "order": 8
                    },
                    {
                        "id": "rule-saturation",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "saturation",
                                "expression": "0.5 + spectralFlatness * 0.5"
                            }
                        ],
                        "order": 9
                    },
                    {
                        "id": "rule-opacity",
                        "enabled": true,
                        "target": "allParticles",
                        "condition": {
                            "operator": "always"
                        },
                        "actions": [
                            {
                                "operator": "set",
                                "output": "opacity",
                                "expression": "0.3 + entityVolume * 0.7"
                            }
                        ],
                        "order": 10
                    }
                ]
            }
        ],
        "ruleGlobalBlocks": {
            "background": [],
            "camera": []
        }
    }
}