ions": [                            {                                "operator": "set",                                "output": "cloudSize",                                "expression": "0.6 + amplitude * 0.4"                            }                        ],                        "order": 3                    },                    {                        "id": "rule-size",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "size",                                "expression": "1 + componentVolume * 4"                            }                        ],                        "order": 4                    },                    {                        "id": "rule-hue",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "hue",                                "expression": "fundamentalNote / 12"                            }                        ],                        "order": 5                    },                    {                        "id": "rule-saturation",                        "enabled": true,                        "target": "allParticles",                        "condition": {                            "operator": "always"                        },                        "actions": [                            {                                "operator": "set",                                "output": "saturation",                        