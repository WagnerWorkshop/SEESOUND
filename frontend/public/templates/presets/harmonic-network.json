{    "schemaVersion": 3,    "name": "harmonic-network",    "params": {        "inputGain": 1.0,        "freqNormMin": 60,        "freqNormMax": 6000,        "frequencyFftSize": 16384,        "cqtDetailsPer10Octaves": 1000,        "fluxWindowFrames": 8,        "binMagnitudeNormMin": -70,        "binMagnitudeNormMax": 0,        "globalRmsNormMin": -60,        "globalRmsNormMax": 0,        "spectralCentroidNormMin": 150,        "spectralCentroidNormMax": 8000,        "spectralFlatnessNormMin": 0,        "spectralFlatnessNormMax": 1,        "defaultParticleSize": 4,        "canvasWidth": 2000,        "canvasHeight": 1000,        "canvasScale": 50,        "defaultBackgroundHue": 0,        "defaultBackgroundSaturation": 0,        "defaultBackgroundLightness": 2,        "maxParticles": 1500000,        "particlesByFrame": 1200,        "blendMode": "screen",        "blendEnabled": 1,        "cameraProjection": "perspective",        "cameraPosZ": 600,        "persistMode": 0,        "postProcessEnabled": 1,        "bloomEnabled": 1,        "bloomStrength": 1.8,        "bloomRadius": 0.8,        "bloomThreshold": 0.1,        "fogEnabled": 1,        "fogDensity": 0.0008,        "ruleEngineEnabled": true,        "ruleSchemaVersion": 3,        "palettes": [],        "tuners": [],        "ruleUiState": {            "collapsedGroups": [],            "collapsedSubgroups": [],            "collapsedRules": [],            "selectedContextGroup": "allParticles"        },        "ruleLayers": [            {                "id": "layer-network",                "name": "Harmonic Network",                "enabled": true,                "order": 0,                "layerShapeType": "cloud",                "spacingMode": "network",                "cloudShape": "spherical",                "definitions": [],                "rules": [                    {                        "id": "rule-repulsion",                        "enabled": true,                        "target": "allParticles",        