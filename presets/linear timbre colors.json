        "target": "spawnedParticles",
        "scope": "spawnedOnly",
        "condition": {
          "operator": "always"
        },
        "actions": [
          {
            "operator": "set",
            "output": "z",
            "expression": "-(normFreq*1.4-0.9)*canvasHeightPx"
