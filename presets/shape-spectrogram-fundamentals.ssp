{"schemaVersion": 1, "createdAt": "2026-07-18T00:00:00.000Z", "updatedAt": "2026-07-18T00:00:00.000Z", "projectName": "Shape Spectrogram", "presetName": "shape-fundamentals", "params": {"inputGain": 1.5, "freqNormMin": 40, "freqNormMax": 16000, "cqtDetailsPer10Octaves": 1000, "frequencyFftSize": 16384, "rhythmFftSize": 1024, "fluxWindowFrames": 10, "adjustForHumanHearing": 0, "binMagnitudeNormMin": -105, "binMagnitudeNormMax": 0, "binFluxNormMin": 0, "binFluxNormMax": 0.5, "binPhaseDeviationNormMin": 0, "binPhaseDeviationNormMax": 3.14, "binAttackTimeNormMin": 5, "binAttackTimeNormMax": 500, "globalRmsNormMin": -60, "globalRmsNormMax": 0, "spectralCentroidNormMin": 40, "spectralCentroidNormMax": 12000, "globalSpectralFluxNormMin": 0, "globalSpectralFluxNormMax": 100, "spectralFlatnessNormMin": 0, "spectralFlatnessNormMax": 1, "componentDistinctness": 0.5, "defaultParticleSize": 1, "canvasWidth": 1855, "canvasHeight": 866, "canvasScale": 100, "defaultBackgroundHue": 0, "defaultBackgroundSaturation": 0, "defaultBackgroundLightness": 0, "maxParticles": 1000000, "particlesByFrame": 2000, "blendEnabled": 0, "blendMode": "screen", "cameraProjection": "axonometric", "cameraAxoPreset": "orthoXY", "cameraPosX": 0, "cameraPosY": 0, "cameraPosZ": 420, "cameraTargetX": 0, "cameraTargetY": 0, "cameraTargetZ": 0, "cameraAngleOfView": 55, "postProcessEnabled": 0, "bloomEnabled": 1, "bloomStrength": 1.15, "bloomRadius": 0.7, "bloomThreshold": 0.18, "fogEnabled": 1, "fogDensity": 0.002, "persistMode": 0, "objectMode": "particle", "uiMode": "advanced", "shapeSparsityTopN": 5, "shapeSmoothingAlpha": 0.18, "ruleBlocks": [], "ruleLayers": [{"id": "layer-fundamentals", "name": "Shape Spectrogram", "enabled": true, "order": 0, "layerShapeType": "particle", "spacingMode": "coordinates", "cloudShape": "cylindrical", "definitions": [], "rules": [{"id": "rule-x-scroll", "target": "spawnedParticles", "enabled": true, "group": "Position", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "x", "expression": "(time / audioLengthSec - 0.5) * canvasWidthPx * 10"}], "order": 0}, {"id": "rule-y-fundamental", "target": "spawnedParticles", "enabled": true, "group": "Position", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "y", "expression": "(fundamentalNormHz - 0.5) * canvasHeightPx"}], "order": 1}, {"id": "rule-size", "target": "spawnedParticles", "enabled": true, "group": "Appearance", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "size", "expression": "shapeDominantValue * 8 + 3"}], "order": 2}, {"id": "rule-count", "target": "spawnedParticles", "enabled": true, "group": "Appearance", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "particleCount", "expression": "shapeDominantValue * 0.8 + 0.1"}], "order": 4}, {"id": "rule-hue", "target": "spawnedParticles", "enabled": true, "group": "Color", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "hue", "expression": "(shapeSawtooth * 0.1 + shapeTriangle * 0.3 + shapeSine * 0.55 + shapeSquare * 0.7 + shapePad * 0.85 + shapeBass * 0.95 + shapeBuzzy * 0.15 + shapeNoise * 0.0 + shapePinkNoise * 0.05 + shapeTransient * 1.0) % 1"}], "order": 5}, {"id": "rule-sat", "target": "spawnedParticles", "enabled": true, "group": "Color", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "saturation", "expression": "shapeDominantValue * 2 + 0.3"}], "order": 6}, {"id": "rule-bright", "target": "spawnedParticles", "enabled": true, "group": "Color", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "brightness", "expression": "fundamentalNormHz * 1.2 + 0.1"}], "order": 7}, {"id": "rule-opacity", "target": "spawnedParticles", "enabled": true, "group": "Color", "condition": {"operator": "always"}, "actions": [{"operator": "set", "output": "opacity", "expression": "shapeDominantValue * 1.2 + 0.15"}], "order": 8}]}], "ruleGlobalBlocks": {"background": [], "camera": []}, "ruleEngineEnabled": true, "ruleSchemaVersion": 3, "palettes": [], "tuners": [], "ruleUiState": {}}, "presetLibrary": []}